# Open PTC Agent Credentials
# This file contains ONLY credentials (API keys, tokens, secrets)
# All configuration should be in config.yaml

# LLM API Keys
ANTHROPIC_API_KEY=your_anthropic_api_key_here
OPENAI_API_KEY=your_openai_api_key_here
MINIMAX_API_KEY=your_minimax_api_key_here
GEMINI_API_KEY=your_google_api_key_here

# Daytona Sandbox
DAYTONA_API_KEY=your_daytona_api_key_here
ALPHA_VANTAGE_API_KEY=your_alpha_vantage_api_key_here

# MCP Server Credentials
GITHUB_TOKEN=your_github_token_here

# GitHub Bot (agent self-improvement — issue reporting, PR proposals)
# Fine-grained PAT from bot machine user (needs: Issues R/W, Contents R/W, Pull Requests R/W)
GITHUB_BOT_TOKEN=your_github_bot_token_here
TAVILY_API_KEY=your_tavily_api_key_here
SERPER_API_KEY=your_serper_api_key_here

# LangSmith Tracing (Optional)
LANGSMITH_TRACING=true
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
LANGSMITH_API_KEY=your_langsmith_api_key_here
LANGSMITH_PROJECT=open-ptc-agent


# =============================================================================
# Cloud Storage Credentials
# Provider is configured in config.yaml (storage.provider)
# =============================================================================

# -----------------------------------------------------------------------------
# AWS S3 Configuration
# -----------------------------------------------------------------------------
AWS_ACCESS_KEY_ID=your_aws_access_key_id_here
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key_here
S3_BUCKET_NAME=your_s3_bucket_name_here
S3_REGION=us-east-1
# Optional: CloudFront URL for faster delivery
# S3_PUBLIC_URL_BASE=https://d1234.cloudfront.net

# -----------------------------------------------------------------------------
# Cloudflare R2
# -----------------------------------------------------------------------------
# R2_ACCOUNT_ID=your_cloudflare_account_id_here
# R2_ACCESS_KEY_ID=your_r2_access_key_id_here
# R2_SECRET_ACCESS_KEY=your_r2_secret_access_key_here
# R2_BUCKET_NAME=your_r2_bucket_name_here
# Optional: Custom domain for public URLs (otherwise uses r2.dev)
# R2_PUBLIC_URL_BASE=https://cdn.yourdomain.com

# -----------------------------------------------------------------------------
# Alibaba Cloud OSS
# -----------------------------------------------------------------------------
# OSS_ACCESS_KEY_ID=your_oss_access_key_id_here
# OSS_ACCESS_KEY_SECRET=your_oss_access_key_secret_here
# OSS_BUCKET_NAME=your_oss_bucket_name_here
# OSS_REGION=oss-cn-hangzhou
# OSS_ENDPOINT=oss-cn-hangzhou.aliyuncs.com
# OSS_MAX_UPLOAD_SIZE=10485760

# Supabase Auth (leave SUPABASE_URL empty to disable auth)
SUPABASE_URL=https://xxxxx.supabase.co

# When SUPABASE_URL is unset, this user ID is used for all requests
AUTH_USER_ID=local-dev-user

# ginlix-auth service (optional — enables membership quotas when set)
# AUTH_SERVICE_URL=http://localhost:8003

# Database configuration
DB_TYPE=postgres
DB_HOST=localhost
DB_PORT=5432
DB_USER=ptc_admin
DB_PASSWORD=your_db_password_here
DB_NAME=ptc_agent

# Redis
REDIS_PASSWORD=your_redis_password_here
REDIS_URL=redis://:your_redis_password_here@localhost:6379/0

# -----------------------------------------------------------------------------
# InfoFlow Base URL
# -----------------------------------------------------------------------------
# INFOFLOW_BASE_URL=InfowFlow_base_url_here

# Optional: enable service-to-service auth (for ginlix-integration)
# INTERNAL_SERVICE_TOKEN=

# ginlix-data (real-time market data proxy — set to enable REST + WS)
# GINLIX_DATA_URL=http://localhost:8005
# GINLIX_DATA_WS_URL is auto-derived from GINLIX_DATA_URL; override if needed:
# GINLIX_DATA_WS_URL=ws://localhost:8005
